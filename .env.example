# Application
APP_NAME=backend-eng-assignment
APP_HOST=127.0.0.1
APP_PORT=8000
APP_RELOAD=true

# Logging
LOG_LEVEL=INFO
LOG_API_REQUESTS=true

# Database
DATABASE_DRIVER=postgresql+asyncpg
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=

# JWT / Authentication
# Set this to a strong random value in local/production .env files.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
